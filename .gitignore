# All subsystems (depgraph, logigraph, graphui) are consolidated into
# this repo via git-filter-repo subtree merge with prefixed paths.
# install.sh used to clone them as separate repos here; that's gone.

# Python bytecode caches
__pycache__/
*.pyc

# setuptools-install stubs (regenerated by `pip install -e .` inside
# depgraph/ or logigraph/). The actual source is at <subsystem>/lib/,
# not at <subsystem>/<subsystem>/. These dirs are pure build artifacts.
depgraph/depgraph/
depgraph/depgraph.egg-info/
logigraph/logigraph/
logigraph/logigraph.egg-info/

# pytest cache
.pytest_cache/

# harness-managed agent worktrees
.claude/

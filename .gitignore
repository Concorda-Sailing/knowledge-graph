# The orchestrator repo's checkout doubles as the bundle dir for a
# tools install (install.sh clones depgraph/, logigraph/, graphui/ as
# siblings of install.sh). Those are independent git repos with their
# own histories — keep them out of this repo's status.
/depgraph/
/logigraph/
/graphui/

# Python bytecode caches
__pycache__/
*.pyc

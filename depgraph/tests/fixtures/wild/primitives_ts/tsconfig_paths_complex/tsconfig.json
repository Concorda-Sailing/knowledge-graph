{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@/components/*": ["src/components/*"],
      "~lib/*": ["src/lib/*"],
      "~lib/utils": ["src/lib/utils.ts"],
      "#root": ["src/index.ts"]
    }
  },
  "include": ["src/**/*"]
}

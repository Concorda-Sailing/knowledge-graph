def _depgraph_default_actor() -> str:
    r = subprocess.run(["git", "config", "user.name"], capture_output=True, text=True)
    if r.returncode == 0 and r.stdout.strip():
        return r.stdout.strip()
    return os.environ.get("USER", "unknown")


def _depgraph_commit_if_changed(paths: list[Path], message: str) -> bool:
    rel = [str(p.relative_to(DEPGRAPH)) for p in paths]
    subprocess.run(["git", "-C", str(DEPGRAPH), "add", *rel], check=True)
    diff = subprocess.run(
        ["git", "-C", str(DEPGRAPH), "diff", "--cached", "--name-only"],
        capture_output=True, text=True,
    )
    if not diff.stdout.strip():
        return False
    subprocess.run(["git", "-C", str(DEPGRAPH), "commit", "-q", "-m", message], check=True)
    return True



#!/usr/bin/env python3
"""
depgraph — CLI entrypoint for regen, lookup, validation.

Subcommands:
  regen [--all|--since REF]    Run extractors and reconcile.
  context <file-or-id>         Print the same block PreToolUse would inject.
  dependents <id> [--depth N]  Walk the reverse graph from <id>.
  orphans [--purge]            List/archive nodes whose source no longer exists.
  validate [--strict]          JSON-Schema validate every node file.
  self-check                   Smoke-test the hook/extractor pipeline.
  flag <id> --reason "..."     Set flagged=true on a node; commits.
  unflag <id>                  Clear flagged; commits.
"""

from __future__ import annotations


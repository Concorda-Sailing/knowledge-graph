#!/bin/bash
# kg-prepush-cascade — installed as a pre-push hook in tracked project
# repos (concorda-api, concorda-web, etc.). When the user pushes code,
# this hook re-extracts depgraph nodes for the changed files, regens
# the logigraph reconcile pass, commits any KG-corpus changes, and
# pushes them to the KG remote. Then the original project push
# proceeds.
#
# Required env vars (baked in by install.sh when the hook is written):
#   KG_DEPGRAPH_DIR   — absolute path to the depgraph corpus data dir
#   KG_LOGIGRAPH_DIR  — absolute path to the logigraph corpus data dir
#
# Optional:
#   KG_CASCADE_BRANCH — branch name to cascade on (default: main).
#                       Skips cascade if KG corpus is on a different branch.
#   KG_CASCADE_NOPUSH=1 — commit but don't push the KG side.
#                        (useful for testing or for users who want manual
#                        control over the KG remote.)
#
# Best-effort: any KG-side failure logs a warning and lets the original
# project push proceed. KG pushes are visible to operators via stderr.
set -u

# Drain pre-push stdin so git doesn't complain.
cat >/dev/null 2>&1 || true

KG_CASCADE_BRANCH="${KG_CASCADE_BRANCH:-main}"

err() { printf "  ⚠ kg-cascade: %s\n" "$*" >&2; }
say() { printf "  ↻ kg-cascade: %s\n" "$*" >&2; }

if [ -z "${KG_DEPGRAPH_DIR:-}" ] && [ -z "${KG_LOGIGRAPH_DIR:-}" ]; then
    err "no KG_DEPGRAPH_DIR or KG_LOGIGRAPH_DIR exported; skipping"
    exit 0
fi

# ---- 1. Regen depgraph if configured ---------------------------------
if [ -n "${KG_DEPGRAPH_DIR:-}" ] && [ -d "$KG_DEPGRAPH_DIR" ]; then
    if command -v depgraph >/dev/null 2>&1; then
        DEPGRAPH_DATA_DIR="$KG_DEPGRAPH_DIR" depgraph regen >/dev/null 2>&1 \
            || err "depgraph regen failed (continuing)"
    else
        err "depgraph CLI not in PATH; skipping"
    fi
fi

# ---- 2. Regen logigraph if configured --------------------------------
if [ -n "${KG_LOGIGRAPH_DIR:-}" ] && [ -d "$KG_LOGIGRAPH_DIR" ]; then
    if command -v logigraph >/dev/null 2>&1; then
        LOGIGRAPH_DATA_DIR="$KG_LOGIGRAPH_DIR" \
        DEPGRAPH_DATA_DIR="${KG_DEPGRAPH_DIR:-}" \
            logigraph regen >/dev/null 2>&1 \
            || err "logigraph regen failed (continuing)"
    else
        err "logigraph CLI not in PATH; skipping"
    fi
fi

# ---- 3. Commit + push each KG corpus if changed ---------------------
for KG_DIR in "${KG_DEPGRAPH_DIR:-}" "${KG_LOGIGRAPH_DIR:-}"; do
    [ -n "$KG_DIR" ] || continue
    [ -d "$KG_DIR/.git" ] || {
        # corpus may be nested under a parent git repo (e.g. concorda/knowledge-graph/)
        # Walk up looking for the enclosing .git.
        if ! git -C "$KG_DIR" rev-parse --git-dir >/dev/null 2>&1; then
            err "$KG_DIR is not inside a git repo; skipping"
            continue
        fi
    }
    (
        cd "$KG_DIR" || exit 0
        current_branch=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
        if [ "$current_branch" != "$KG_CASCADE_BRANCH" ]; then
            err "$(basename "$KG_DIR") on branch '$current_branch', not '$KG_CASCADE_BRANCH'; skipping"
            exit 0
        fi
        # Stage corpus changes only (avoid sweeping in stray files)
        git add nodes/ dossiers/ telemetry/ 2>/dev/null || true
        if git diff --cached --quiet 2>/dev/null; then
            exit 0  # nothing to commit
        fi
        # Build a commit message referencing the target repo
        target_name=$(basename "$(git -C "$OLDPWD" rev-parse --show-toplevel 2>/dev/null)" 2>/dev/null || echo "target repo")
        target_sha=$(git -C "$OLDPWD" rev-parse --short HEAD 2>/dev/null || echo "?")
        commit_msg="chore: regen cascaded from ${target_name} push @ ${target_sha}

Auto-generated by kg-prepush-cascade. Refreshes depgraph node
metadata + logigraph claim hashes + semantic index after a push
on the source repo. Pairs with the source commit so a knowledge-
graph viewer reflects code at the time of push."
        if git commit -q -m "$commit_msg" --no-verify 2>/dev/null; then
            say "committed regen in $(basename "$KG_DIR")"
            if [ -z "${KG_CASCADE_NOPUSH:-}" ]; then
                if git push --quiet 2>/dev/null; then
                    say "pushed regen cascade for $(basename "$KG_DIR")"
                else
                    err "push failed for $(basename "$KG_DIR") (continuing)"
                fi
            fi
        fi
    )
done

# ---- 4. Always allow the original target push to proceed ------------
exit 0

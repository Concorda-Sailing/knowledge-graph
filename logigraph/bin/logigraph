# ===== rule pipeline =========================================================
# rule-rank   list rule nodes by definition_status, ranked by claim count
# rule-stub   create a stub rule JSON node + placeholder dossier from a candidate
# rule-draft  emit an LLM-drafting context bundle for one rule (template + claims sources + domain + sibling rules)
# rule-finalize  write the dossier body for a stub/drafted rule with frontmatter
# rule-bump   promote a rule's definition_status (default → human_reviewed)


def _rule_node_path(rule_id: str) -> Path:
    """rule::category::short_name → nodes/rules/category__short_name.json"""
    if not rule_id.startswith("rule::"):
        raise ValueError(f"not a rule id: {rule_id}")
    parts = rule_id.split("::", 2)
    if len(parts) != 3:
        raise ValueError(f"malformed rule id (expected 3 segments): {rule_id}")
    return RULES_DIR / f"{parts[1]}__{parts[2]}.json"


def _rule_dossier_path(rule_id: str) -> Path:
    parts = rule_id.split("::", 2)
    return LOGIGRAPH / "dossiers" / "rules" / f"{parts[1]}__{parts[2]}.md"


def _rule_dossier_rel(rule_id: str) -> str:
    parts = rule_id.split("::", 2)
    return f"dossiers/rules/{parts[1]}__{parts[2]}.md"


_DOMAIN_PREFIXES = ("role", "resource", "attribute", "relationship", "action")


def _domain_node_path(domain_id: str) -> Path:
    """<subkind>::<category>::<short_name> → nodes/domain/<subkind>__<category>__<short_name>.json"""
    parts = domain_id.split("::")
    if len(parts) != 3 or parts[0] not in _DOMAIN_PREFIXES:
        raise ValueError(f"not a valid domain id: {domain_id}")
    return DOMAIN_DIR / f"{parts[0]}__{parts[1]}__{parts[2]}.json"


def _domain_dossier_path(domain_id: str) -> Path:
    parts = domain_id.split("::")
    return LOGIGRAPH / "dossiers" / "domain" / f"{parts[0]}__{parts[1]}__{parts[2]}.md"


def _process_node_path(process_id: str) -> Path:
    """process::<category>::<short_name> → nodes/processes/<category>__<short_name>.json"""
    parts = process_id.split("::")
    if len(parts) != 3 or parts[0] != "process":
        raise ValueError(f"not a valid process id: {process_id}")
    return LOGIGRAPH / "nodes" / "processes" / f"{parts[1]}__{parts[2]}.json"


def _process_dossier_path(process_id: str) -> Path:
    parts = process_id.split("::")
    return LOGIGRAPH / "dossiers" / "processes" / f"{parts[1]}__{parts[2]}.md"


def _process_dossier_rel(process_id: str) -> str:
    parts = process_id.split("::")
    return f"dossiers/processes/{parts[1]}__{parts[2]}.md"


def _process_dossier_path(process_id: str) -> Path:
    parts = process_id.split("::")
    return LOGIGRAPH / "dossiers" / "processes" / f"{parts[1]}__{parts[2]}.md"



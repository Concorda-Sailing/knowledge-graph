#!/usr/bin/env python3
"""logigraph — CLI entrypoint. Constructs a Context from the resolved
data dir and dispatches into logigraph.lib.cli subcommand modules.
"""
from __future__ import annotations

import sys
from pathlib import Path

# Add framework root so `logigraph.lib.*` resolves as a fully-qualified package.
_FRAMEWORK_ROOT = Path(__file__).resolve().parents[2]  # ~/tools/knowledge-graph
sys.path.insert(0, str(_FRAMEWORK_ROOT))

from logigraph.lib.config import resolve_data_dir  # noqa: E402
from logigraph.lib.cli import build_parser  # noqa: E402
from logigraph.lib.cli.context import Context  # noqa: E402


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    data_dir = resolve_data_dir("LOGIGRAPH_DATA_DIR")
    ctx = Context.from_data_dir(data_dir)
    return args.func(args, ctx)


if __name__ == "__main__":
    sys.exit(main())

#!/usr/bin/env python3
"""
logigraph — CLI for the rule + ontology graph.

Subcommands:
  regen                       Run extractors and reconcile (build indexes,
                              validate claims, refresh remote_hash).
  context <file-or-id>        Print the same block PreToolUse would inject.
  validate                    JSON-Schema check + dossier section check.
  rules-for <depgraph-id>     List rules that claim a depgraph node.
  fan-out [--threshold N]     Rank rules by claim count (refactor signal).
  gaps                        Orphan rules / orphan ontology refs / stale
                              claims.
  dossiers --status           [Backwards-compat alias for `stats`.]
  stats [--telemetry]         Curation backlog + optional injection metrics.
  self-check                  Smoke-test the hook with a fake payload.
"""

from __future__ import annotations

import argparse
import json
import os
import re
import subprocess
import sys
from pathlib import Path

LOGIGRAPH = Path(os.environ.get("CONCORDA_LOGIGRAPH_PATH", Path.home() / "concorda" / "logigraph")).resolve()
DEPGRAPH = Path(os.environ.get("CONCORDA_DEPGRAPH_PATH", Path.home() / "concorda" / "depgraph")).resolve()
NODES = LOGIGRAPH / "nodes"
ONTOLOGY_DIR = NODES / "ontology"
RULES_DIR = NODES / "rules"
INDEX_DIR = NODES / "_index"
BY_CODE_INDEX = INDEX_DIR / "by_code.json"
BY_FILE_INDEX = INDEX_DIR / "by_file.json"
BY_ONTOLOGY_INDEX = INDEX_DIR / "by_ontology.json"
CORPUS_META = NODES / "_meta.json"
ONTOLOGY_SCHEMA = LOGIGRAPH / "schema" / "ontology.schema.json"
RULE_SCHEMA = LOGIGRAPH / "schema" / "rule.schema.json"
TELEMETRY_DIR = LOGIGRAPH / "telemetry"
INJECTIONS_LOG = TELEMETRY_DIR / "injections.jsonl"
ACKS_LOG = TELEMETRY_DIR / "acknowledgments.jsonl"

REQUIRED_RULE_DOSSIER_SECTIONS = (
    "## The rule",
    "## Why it exists",
    "## Decision table",
)
REQUIRED_ONTOLOGY_ROLE_DOSSIER_SECTIONS = (
    "## Plain definition",
    "## They can",
)


def _is_node_file(path: Path) -> bool:
    if path.name.startswith("_"):
        return False
    if any(p.startswith("_") for p in path.parts):
        return False
    return True


def load_all_nodes() -> dict[str, tuple[Path, dict]]:
    """Return id -> (file_path, node_dict) for every authored logigraph node."""
    out: dict[str, tuple[Path, dict]] = {}
    for path in NODES.rglob("*.json"):
        if not _is_node_file(path):
            continue
        try:
            data = json.loads(path.read_text())
        except json.JSONDecodeError as e:
            print(f"WARN: invalid JSON {path}: {e}", file=sys.stderr)
            continue
        nid = data.get("id")
        if not nid:
            continue
        out[nid] = (path, data)
    return out


def load_depgraph_corpus() -> dict[str, dict]:
    """Read depgraph nodes once. Returns id -> node dict."""
    by_id: dict[str, dict] = {}
    dnodes = DEPGRAPH / "nodes"
    if not dnodes.exists():
        return by_id
    for path in dnodes.rglob("*.json"):
        if path.name.startswith("_") or any(p.startswith("_") for p in path.parts):
            continue
        try:
            data = json.loads(path.read_text())
        except (OSError, json.JSONDecodeError):
            continue
        nid = data.get("id")
        if nid:
            by_id[nid] = data
    return by_id


def mark_regen_in_progress() -> None:
    """Atomic marker: if regen crashes mid-run, this stays as in_progress
    and the hook surfaces a banner. reconcile.py flips it to complete on
    success."""
    import datetime as _dt

    NODES.mkdir(parents=True, exist_ok=True)
    payload: dict = {
        "schema_version": 1,
        "regen_status": "in_progress",
        "started_at": _dt.datetime.now(_dt.timezone.utc).isoformat(),
    }
    if CORPUS_META.exists():
        try:
            existing = json.loads(CORPUS_META.read_text())
            payload = {**existing, **payload}
        except (OSError, json.JSONDecodeError):
            pass
    tmp = CORPUS_META.with_suffix(".json.tmp")
    tmp.write_text(json.dumps(payload, indent=2, sort_keys=False) + "\n")
    tmp.replace(CORPUS_META)


def cmd_regen(args: argparse.Namespace) -> int:
    mark_regen_in_progress()
    rc = subprocess.call(["python3", str(LOGIGRAPH / "extractors" / "reconcile.py")])
    return 0 if rc == 0 else 1


def _validate_json_schema(data: dict, schema_path: Path) -> str | None:
    """Return None if valid, else error message."""
    try:
        import jsonschema
    except ImportError:
        return "jsonschema not installed; pip install jsonschema"
    try:
        schema = json.loads(schema_path.read_text())
        jsonschema.validate(data, schema)
    except jsonschema.ValidationError as e:
        return str(e.message)
    except json.JSONDecodeError as e:
        return f"schema parse error: {e}"
    return None


def _check_dossier_sections(dossier_path: Path, required: tuple[str, ...]) -> list[str]:
    """Return list of missing section headings."""
    if not dossier_path.exists():
        return list(required)
    text = dossier_path.read_text()
    return [s for s in required if s not in text]


def cmd_validate(args: argparse.Namespace) -> int:
    nodes = load_all_nodes()
    bad = 0
    stub_with_todo = 0

    for nid, (path, data) in nodes.items():
        kind = data.get("kind")
        if kind == "ontology":
            err = _validate_json_schema(data, ONTOLOGY_SCHEMA)
            if err:
                print(f"INVALID {path}: {err}", file=sys.stderr)
                bad += 1
                continue
            if data.get("subkind") == "role":
                dossier_rel = data.get("dossier")
                if dossier_rel:
                    missing = _check_dossier_sections(
                        LOGIGRAPH / dossier_rel,
                        REQUIRED_ONTOLOGY_ROLE_DOSSIER_SECTIONS,
                    )
                    if missing and data.get("definition_status") != "stub":
                        print(f"DOSSIER {path}: missing sections {missing}", file=sys.stderr)
                        bad += 1
        elif kind == "rule":
            err = _validate_json_schema(data, RULE_SCHEMA)
            if err:
                print(f"INVALID {path}: {err}", file=sys.stderr)
                bad += 1
                continue
            dossier_rel = data.get("dossier")
            if dossier_rel:
                missing = _check_dossier_sections(
                    LOGIGRAPH / dossier_rel, REQUIRED_RULE_DOSSIER_SECTIONS
                )
                if missing and data.get("definition_status") != "stub":
                    print(f"DOSSIER {path}: missing sections {missing}", file=sys.stderr)
                    bad += 1
        else:
            print(f"UNKNOWN KIND {path}: kind={kind}", file=sys.stderr)
            bad += 1

        if data.get("definition_status") == "stub":
            stub_with_todo += 1

    if bad:
        return 1
    print(f"all nodes valid ({len(nodes)} total, {stub_with_todo} stub)")
    return 0


def cmd_rules_for(args: argparse.Namespace) -> int:
    if not BY_CODE_INDEX.exists():
        print("by_code index not built — run `bin/logigraph regen`", file=sys.stderr)
        return 1
    idx = json.loads(BY_CODE_INDEX.read_text())
    rule_ids = idx.get("by_target", {}).get(args.depgraph_id, [])
    if not rule_ids:
        print(f"no rules claim {args.depgraph_id}")
        return 0
    nodes = load_all_nodes()
    for rid in rule_ids:
        node = nodes.get(rid, (None, {}))[1]
        title = node.get("title", rid)
        statement = node.get("statement", "")
        print(f"- {rid}")
        print(f"  {title}")
        if statement:
            print(f"  → {statement}")
    return 0


def cmd_fan_out(args: argparse.Namespace) -> int:
    nodes = load_all_nodes()
    rules = [(nid, data) for nid, (_, data) in nodes.items() if data.get("kind") == "rule"]
    rules.sort(key=lambda x: -(x[1].get("fan_out") or len(x[1].get("claims_code") or [])))
    threshold = args.threshold
    print(f"{'fan-out':<8} rule")
    print(f"{'-'*8} {'-'*60}")
    for nid, data in rules:
        fan_out = data.get("fan_out") or len(data.get("claims_code") or [])
        if fan_out < threshold:
            continue
        print(f"{fan_out:<8} {nid}")
    return 0


def cmd_gaps(args: argparse.Namespace) -> int:
    nodes = load_all_nodes()
    ontology_ids = {nid for nid, (_, d) in nodes.items() if d.get("kind") == "ontology"}
    depgraph_corpus = load_depgraph_corpus()
    depgraph_ids = set(depgraph_corpus.keys())

    orphan_claims: list[tuple[str, str]] = []
    orphan_ontology_refs: list[tuple[str, str]] = []
    stale_claims: list[tuple[str, str]] = []

    for nid, (_, data) in nodes.items():
        if data.get("kind") != "rule":
            continue
        for ref in data.get("references_ontology", []):
            if ref not in ontology_ids:
                orphan_ontology_refs.append((nid, ref))
        for claim in data.get("claims_code", []):
            cid = claim.get("depgraph_id")
            if cid not in depgraph_ids:
                orphan_claims.append((nid, cid))
                continue
            remote = claim.get("remote_hash")
            current = depgraph_corpus[cid].get("structural_hash")
            if remote and current and remote != current:
                stale_claims.append((nid, cid))

    if orphan_claims:
        print(f"ORPHAN CLAIMS ({len(orphan_claims)}):")
        for rule_id, claim_id in orphan_claims:
            print(f"  {rule_id} → {claim_id}")
    if orphan_ontology_refs:
        print(f"ORPHAN ONTOLOGY REFS ({len(orphan_ontology_refs)}):")
        for rule_id, ref in orphan_ontology_refs:
            print(f"  {rule_id} → {ref}")
    if stale_claims:
        print(f"STALE CLAIMS ({len(stale_claims)}):")
        for rule_id, claim_id in stale_claims:
            print(f"  {rule_id} → {claim_id}")

    total = len(orphan_claims) + len(orphan_ontology_refs) + len(stale_claims)
    if total == 0:
        print("no gaps")
        return 0
    return 1


def cmd_dossiers(args: argparse.Namespace) -> int:
    """Backwards-compat alias for `stats` with no flags."""
    args.telemetry = False
    return cmd_stats(args)


def _load_telemetry_events(path: Path, since_hours: int | None = None) -> list[dict]:
    """Read a JSONL log; if since_hours is given, filter to events newer
    than that. Returns an empty list if the file is missing or unreadable."""
    if not path.exists():
        return []
    import datetime as _dt
    cutoff = None
    if since_hours is not None:
        cutoff = _dt.datetime.now(_dt.timezone.utc) - _dt.timedelta(hours=since_hours)
    out: list[dict] = []
    try:
        with path.open() as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    ev = json.loads(line)
                except json.JSONDecodeError:
                    continue
                if cutoff is not None:
                    ts_str = ev.get("ts", "")
                    try:
                        ts = _dt.datetime.fromisoformat(ts_str)
                    except ValueError:
                        continue
                    if ts < cutoff:
                        continue
                out.append(ev)
    except OSError:
        return []
    return out


def cmd_stats(args: argparse.Namespace) -> int:
    """Curation backlog + (optional) telemetry rollup. Designed to fit in
    ~30 lines of output for typical state — eyeballable, not dashboard."""
    nodes = load_all_nodes()
    rules = [(nid, data) for nid, (_, data) in nodes.items() if data.get("kind") == "rule"]
    ontology = [(nid, data) for nid, (_, data) in nodes.items() if data.get("kind") == "ontology"]

    # Definition_status breakdown.
    by_kind: dict[str, dict[str, int]] = {}
    for nid, (_, data) in nodes.items():
        kind = data.get("kind", "?")
        by_kind.setdefault(kind, {"stub": 0, "llm_drafted": 0, "human_reviewed": 0, "missing": 0, "other": 0})
        st = data.get("definition_status")
        bucket = st if st in ("stub", "llm_drafted", "human_reviewed") else ("missing" if st is None else "other")
        by_kind[kind][bucket] += 1

    # Stale claims — read directly from rule claims to avoid recomputing.
    stale_claims = sum(
        1
        for _nid, data in rules
        for c in data.get("claims_code", [])
        if c.get("stale")
    )
    total_claims = sum(len(data.get("claims_code", [])) for _nid, data in rules)

    print("# Logigraph stats")
    print()
    print(f"  rules:      {len(rules)}")
    print(f"  ontology:   {len(ontology)}")
    print(f"  claims:     {total_claims}  (stale: {stale_claims})")
    print()
    print("## Definition status")
    for kind, kc in sorted(by_kind.items()):
        breakdown = ", ".join(f"{st}={n}" for st, n in kc.items() if n)
        print(f"  {kind:<10} {breakdown}")

    if args.telemetry:
        injections = _load_telemetry_events(INJECTIONS_LOG)
        acks = _load_telemetry_events(ACKS_LOG)
        recent_injections = _load_telemetry_events(INJECTIONS_LOG, since_hours=24 * 7)
        recent_acks = _load_telemetry_events(ACKS_LOG, since_hours=24 * 7)

        print()
        print("## Telemetry (all-time)")
        print(f"  total injections:        {len(injections)}")
        print(f"  total acknowledgments:   {len(acks)}")
        print()
        print("## Telemetry (last 7 days)")
        print(f"  injections:              {len(recent_injections)}")
        print(f"  acknowledgments:         {len(recent_acks)}")

        # Per-rule breakdown.
        rule_inj: dict[str, int] = {}
        rule_ack: dict[str, int] = {}
        for ev in injections:
            rid = ev.get("rule_id")
            if rid:
                rule_inj[rid] = rule_inj.get(rid, 0) + 1
        for ev in acks:
            rid = ev.get("rule_id")
            if rid:
                rule_ack[rid] = rule_ack.get(rid, 0) + 1

        if rule_inj:
            print()
            print("## Top-injected rules (all-time, with ack rate)")
            ranked = sorted(rule_inj.items(), key=lambda kv: -kv[1])[:10]
            print(f"  {'inj':>5}  {'ack':>5}  {'rate':>5}  rule")
            print(f"  {'-'*5}  {'-'*5}  {'-'*5}  {'-'*40}")
            for rid, inj_n in ranked:
                ack_n = rule_ack.get(rid, 0)
                rate = (ack_n / inj_n) if inj_n > 0 else 0.0
                print(f"  {inj_n:>5}  {ack_n:>5}  {rate*100:>4.0f}%  {rid}")

            # Highlight low-ack-rate rules — candidates for prose rework.
            low_ack = [(rid, inj_n, rule_ack.get(rid, 0)) for rid, inj_n in rule_inj.items()
                       if inj_n >= 3 and (rule_ack.get(rid, 0) / inj_n) < 0.3]
            if low_ack:
                print()
                print("## Low ack rate — candidates for prose rework")
                for rid, inj_n, ack_n in sorted(low_ack, key=lambda x: -x[1]):
                    print(f"  {rid}: {inj_n} injected, {ack_n} acknowledged")

    return 0


def repo_relative(abs_path: str) -> tuple[str, str] | None:
    """Same shape as depgraph's helper. /home/lgreenlee/concorda-api/foo/bar.py
    → ('concorda-api', 'foo/bar.py')."""
    home = str(Path.home())
    p = Path(abs_path).expanduser().resolve()
    parts = p.parts
    home_parts = Path(home).parts
    if len(parts) <= len(home_parts):
        return None
    if parts[: len(home_parts)] != home_parts:
        return None
    seg = parts[len(home_parts)]
    if not seg.startswith("concorda"):
        return None
    rel = "/".join(parts[len(home_parts) + 1 :])
    return seg, rel


def find_rules_for_target(target: str) -> list[str]:
    """If target looks like a file path, return rule_ids that claim any
    depgraph node living in that file. If target looks like a node id
    (rule:: or ontology subkind prefix), return [target] verbatim."""
    if target.startswith(("rule::", "role::", "resource::", "action::", "attribute::")):
        return [target]
    if not BY_FILE_INDEX.exists():
        print("by_file index not built — run `bin/logigraph regen`", file=sys.stderr)
        return []
    idx = json.loads(BY_FILE_INDEX.read_text())
    rr = repo_relative(target)
    if not rr:
        # try treating as repo-relative directly
        for repo_name in ("concorda-api", "concorda-web", "concorda-test", "concorda-expo"):
            cand = Path.home() / repo_name / target
            if cand.exists():
                rr = (repo_name, target)
                break
    if not rr:
        return []
    key = f"{rr[0]}/{rr[1]}"
    return idx.get("by_file", {}).get(key, [])


def cmd_context(args: argparse.Namespace) -> int:
    nodes = load_all_nodes()
    rule_ids = find_rules_for_target(args.target)
    if not rule_ids:
        print(f"no rules apply to: {args.target}")
        return 0
    for rid in rule_ids:
        if rid not in nodes:
            print(f"WARN: index points to missing rule {rid}", file=sys.stderr)
            continue
        path, data = nodes[rid]
        print(f"# {data.get('title', rid)}")
        print(f"id: {rid}  ·  fan_out: {data.get('fan_out') or len(data.get('claims_code') or [])}")
        print(f"statement: {data.get('statement', '')}")
        print()
        for ref in data.get("references_ontology", []):
            ont = nodes.get(ref, (None, {}))[1]
            summary = ont.get("summary", "")
            if summary:
                print(f"  · {ref}: {summary}")
        print()
        dossier_rel = data.get("dossier")
        if dossier_rel and (LOGIGRAPH / dossier_rel).exists():
            print((LOGIGRAPH / dossier_rel).read_text())
        else:
            print("_no dossier_")
        print()
    return 0


def cmd_self_check(args: argparse.Namespace) -> int:
    """Run the PreToolUse hook against a fake payload and print stdout."""
    payload = json.dumps(
        {
            "tool_name": "Edit",
            "tool_input": {
                "file_path": str(Path.home() / "concorda-api" / "routers" / "events.py")
            },
        }
    )
    proc = subprocess.run(
        ["python3", str(LOGIGRAPH / "hooks" / "pre_edit_inject.py")],
        input=payload,
        capture_output=True,
        text=True,
        timeout=5,
    )
    print("hook stdout:")
    print(proc.stdout)
    if proc.returncode != 0:
        print(f"FAILED rc={proc.returncode}", file=sys.stderr)
        print(proc.stderr, file=sys.stderr)
        return 1
    return 0


def main() -> int:
    parser = argparse.ArgumentParser(prog="logigraph")
    sub = parser.add_subparsers(dest="cmd", required=True)

    p_regen = sub.add_parser("regen")
    p_regen.set_defaults(func=cmd_regen)

    p_val = sub.add_parser("validate")
    p_val.set_defaults(func=cmd_validate)

    p_ctx = sub.add_parser("context")
    p_ctx.add_argument("target")
    p_ctx.set_defaults(func=cmd_context)

    p_rf = sub.add_parser("rules-for")
    p_rf.add_argument("depgraph_id")
    p_rf.set_defaults(func=cmd_rules_for)

    p_fo = sub.add_parser("fan-out")
    p_fo.add_argument("--threshold", type=int, default=1)
    p_fo.set_defaults(func=cmd_fan_out)

    p_g = sub.add_parser("gaps")
    p_g.set_defaults(func=cmd_gaps)

    p_d = sub.add_parser("dossiers")
    p_d.add_argument("--status", action="store_true")
    p_d.set_defaults(func=cmd_dossiers)

    p_s = sub.add_parser("stats", help="Curation backlog + optional telemetry rollup")
    p_s.add_argument("--telemetry", action="store_true",
                     help="Include injection/acknowledgment metrics from telemetry/")
    p_s.set_defaults(func=cmd_stats)

    p_sc = sub.add_parser("self-check")
    p_sc.set_defaults(func=cmd_self_check)

    args = parser.parse_args()
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())

  "id": "rule::auth::tier_c_org_scope_chokepoint",
  "kind": "rule",
  "title": "Cross-org mutations must funnel through can_administer_orgs",
  "statement": "Every mutating endpoint that touches an org-owned resource (organization, regatta, event, product, discount, series, billing contact) must funnel its authorization decision through AuthUser.can_administer_orgs(owning_org_ids) after resolving the resource's owning-org set \u2014 not just check role type. Checking that the caller is an org_admin is necessary but not sufficient.",
  "references_ontology": [
    "role::system::org_admin",
    "role::system::system_admin",
    "resource::concorda::organization",
    "resource::concorda::regatta",
    "resource::concorda::event"
  ],
